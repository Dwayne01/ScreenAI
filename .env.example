# AI Provider: "claude" or "openai"
AI_PROVIDER=claude

# API Keys — fill in whichever provider you use
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Default prompt sent with each screenshot
AI_PROMPT=Describe what you see in this screenshot in detail. Include any text, UI elements, and relevant context.

# Global hotkey for capture (pynput format)
# macOS examples: <cmd>+<shift>+s  or  <ctrl>+<shift>+s
# Linux/Windows:  <ctrl>+<shift>+s
HOTKEY=<cmd>+<shift>+s

# Server settings
HOST=0.0.0.0
PORT=8765

# Monitor to capture (1 = primary, 0 = all monitors combined)
MONITOR_INDEX=1

# Max width for screenshot transmitted to browser (px). Full res sent to AI.
MAX_DISPLAY_WIDTH=1920
